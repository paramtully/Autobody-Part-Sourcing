{
  "name": "autobody-part-sourcing",
  "private": true,
  "workspaces": [
    "apps/*",
    "apps/workers/*",
    "src/db",
    "src/vendors",
    "src/ordering"
  ],
  "scripts": {
    "setup": "npx drizzle-kit push && npm run seed",
    "seed": "tsx scripts/seed.ts",
    "dev": "npm run dev -w apps/api & npm run dev -w apps/client",
    "ingest": "npm run dev -w apps/workers/listingWorker",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --forceExit"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "@types/archiver": "^7.0.0",
    "@types/jest": "^29.5.14",
    "@types/supertest": "^6.0.3",
    "archiver": "^8.0.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.44.0",
    "esbuild": "^0.28.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.22.3"
  },
  "dependencies": {
    "fast-xml-parser": "^5.8.0"
  }
}
