{
  "version": 2,
  "installCommand": "cd ../.. && npm ci --workspaces --include-workspace-root",
  "builds": [
    {
      "src": "dist/server.cjs",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 30
      }
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "dist/server.cjs" }]
}
