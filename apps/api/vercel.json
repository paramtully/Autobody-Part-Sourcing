{
  "version": 2,
  "builds": [
    {
      "src": "server.ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 30,
        "includeFiles": [
          "../../src/db/**",
          "../../src/ordering/**",
          "../../src/affiliate/**"
        ]
      }
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "server.ts" }]
}
